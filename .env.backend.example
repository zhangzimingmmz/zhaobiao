# Copy to .env.backend and replace all placeholder secrets before first startup.

# API 服务绑定地址（内网地址，通过 Traefik 暴露到公网）
API_PUBLISH_BIND=100.64.0.5:8000
# API 内部访问地址（scheduler 使用）
API_BASE_URL=http://api:8000
# 数据目录（SQLite 数据库存储位置）
DATA_DIR=./data
# 日志目录
LOG_DIR=./logs

# 公网域名配置（由 100.64.0.7 上的 Traefik 提供 HTTPS 反向代理）
PUBLIC_ADMIN_DOMAIN=admin-zhaobiao.zhangziming.cn
PUBLIC_API_DOMAIN=api-zhaobiao.zhangziming.cn

# 管理员认证配置（生产环境必须修改）
ADMIN_USERNAME=admin
ADMIN_TOKEN=replace-with-a-strong-admin-token
ADMIN_PASSWORD=replace-with-a-strong-admin-password
# reviewer 环境变量仅用于首次启动兼容导入；日常新增/停用/改密请改用后台“审核员管理”
ADMIN_REVIEWER1_USERNAME=reviewer1
ADMIN_REVIEWER1_PASSWORD=replace-with-a-strong-reviewer1-password
ADMIN_REVIEWER2_USERNAME=reviewer2
ADMIN_REVIEWER2_PASSWORD=replace-with-a-strong-reviewer2-password
JWT_SECRET=replace-with-a-strong-jwt-secret

# 爬虫控制面配置
ADMIN_CRAWL_BACKFILL_MAX_DAYS=7
ADMIN_CRAWL_DISPATCH_INTERVAL=1.0
SCHEDULER_SUBMIT_TIMEOUT_SECONDS=20

# 管理前端配置
ADMIN_FRONTEND_PUBLISH_BIND=100.64.0.5:8091
ADMIN_FRONTEND_API_BASE=https://api-zhaobiao.zhangziming.cn

# 注意：
# 1. IP 池配置位于 crawler/site2/config.py，需要单独修改
# 2. 修改配置后需要重新构建镜像：docker compose -f docker-compose.backend.yml build --no-cache
# 3. 公网访问需要在 100.64.0.7 上配置 Traefik 动态路由
